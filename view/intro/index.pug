- let presets = [{ format: 'HEX', label: '#0ea5e9', color: '#0ea5e9' }, { format: 'RGB', label: 'rgb(34 197 94)', color: 'rgb(34 197 94)' }]

section.intro( aria-label="Introdução ao conversor" )
  p.intro_text
    = `Cole um valor em HEX, RGB, HSL ou OKLCH e veja a conversão em ${LCH ? 'LCH' : 'OKLCH'} em tempo real.`
  .intro_actions
    span.intro_kicker Exemplos rápidos
    .intro_presets
      each preset in presets
        button.intro_preset(
          type="button"
          data-color=preset.color
          aria-label=`Carregar exemplo ${preset.label} em ${preset.format}`
        )
          span.intro_presetFormat= preset.format
          span.intro_presetLabel= preset.label
